# Managed b-agentic command governance for Codex CLI.
# These rules only cover commands that request to run outside the sandbox.

# Mirror governance for RTK-wrapped shell commands because the kernel routes
# every shell command through `rtk` when it is available.

prefix_rule(
    pattern = ["rtk", "git", "reset", "--hard"],
    decision = "forbidden",
    justification = "b-agentic never resets user work autonomously.",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "b-agentic never resets user work autonomously.",
)

prefix_rule(
    pattern = ["rtk", "git", "clean", "-f"],
    decision = "forbidden",
    justification = "b-agentic never deletes untracked user work autonomously.",
)

prefix_rule(
    pattern = ["git", "clean", "-f"],
    decision = "forbidden",
    justification = "b-agentic never deletes untracked user work autonomously.",
)

prefix_rule(
    pattern = ["rtk", "git", "push", "--force"],
    decision = "forbidden",
    justification = "b-agentic never force-pushes.",
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "b-agentic never force-pushes.",
)

prefix_rule(
    pattern = ["rtk", "git", "commit"],
    decision = "prompt",
    justification = "Commits require explicit approval.",
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Commits require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "git", "pull"],
    decision = "prompt",
    justification = "Pulls require explicit approval.",
)

prefix_rule(
    pattern = ["git", "pull"],
    decision = "prompt",
    justification = "Pulls require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "git", "revert"],
    decision = "prompt",
    justification = "History-changing commands require explicit approval.",
)

prefix_rule(
    pattern = ["git", "revert"],
    decision = "prompt",
    justification = "History-changing commands require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "npm", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["npm", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "pnpm", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["pnpm", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "yarn", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["yarn", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "bun", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["bun", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "git", "branch", "-D"],
    decision = "forbidden",
    justification = "b-agentic never deletes branches autonomously.",
)

prefix_rule(
    pattern = ["git", "branch", "-D"],
    decision = "forbidden",
    justification = "b-agentic never deletes branches autonomously.",
)

prefix_rule(
    pattern = ["rtk", "git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "b-agentic never force-pushes.",
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "b-agentic never force-pushes.",
)

prefix_rule(
    pattern = ["rtk", "git", "push"],
    decision = "prompt",
    justification = "Pushes require explicit approval.",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "rm", "-rf"],
    decision = "prompt",
    justification = "Recursive deletion requires explicit approval; temp/build cleanups are allowed when scoped.",
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "prompt",
    justification = "Recursive deletion requires explicit approval; temp/build cleanups are allowed when scoped.",
)

prefix_rule(
    pattern = ["rtk", "docker", "system", "prune"],
    decision = "forbidden",
    justification = "b-agentic never prunes Docker resources autonomously.",
)

prefix_rule(
    pattern = ["docker", "system", "prune"],
    decision = "forbidden",
    justification = "b-agentic never prunes Docker resources autonomously.",
)

prefix_rule(
    pattern = ["rtk", "docker", "volume", "rm"],
    decision = "forbidden",
    justification = "b-agentic never removes Docker volumes autonomously.",
)

prefix_rule(
    pattern = ["docker", "volume", "rm"],
    decision = "forbidden",
    justification = "b-agentic never removes Docker volumes autonomously.",
)

prefix_rule(
    pattern = ["rtk", "pip", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["pip", "install"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "poetry", "add"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["poetry", "add"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "cargo", "add"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["cargo", "add"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["rtk", "go", "get"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)

prefix_rule(
    pattern = ["go", "get"],
    decision = "prompt",
    justification = "Dependency writes require explicit approval.",
)
