    "playwright_browser_resize": "allow",
    "playwright_browser_hover": "allow",
    "playwright_browser_close": "allow",
    "playwright_browser_tabs": "allow",
    "playwright_browser_click": "ask",
    "playwright_browser_type": "ask",
    "playwright_browser_fill_form": "ask",
    "playwright_browser_press_key": "ask",
    "playwright_browser_select_option": "ask",
    "playwright_browser_file_upload": "ask",
    "playwright_browser_drop": "ask",
    "playwright_browser_drag": "ask",
    "playwright_browser_evaluate": "ask",
    "playwright_browser_run_code_unsafe": "ask",
    "playwright_browser_handle_dialog": "ask"
