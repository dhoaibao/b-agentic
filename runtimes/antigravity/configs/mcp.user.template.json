{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "antigravity",
        "--project-from-cwd",
        "--open-web-dashboard",
        "false"
      ],
      "env": {}
    },
    "context7": {
      "type": "remote",
      "serverUrl": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY:-}"
      }
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"],
      "env": {
        "CODEGRAPH_TELEMETRY": "0"
      }
    },
    "brave-search": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "@brave/brave-search-mcp-server@2.0.85", "--transport", "stdio"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY:-}"
      }
    },
    "firecrawl": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "firecrawl-mcp@3.22.1"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY:-}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "@playwright/mcp@0.0.77", "--isolated"],
      "env": {}
    }
  }
}
