{
  "disableSkillShellExecution": true,
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "mcp__context7__*",
      "mcp__brave-search__*",
      "mcp__firecrawl__*",
      "mcp__playwright__*",
      "mcp__gitnexus__*"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(npm install *)",
      "Bash(pnpm install *)",
      "Bash(yarn install *)",
      "Bash(bun install *)",
