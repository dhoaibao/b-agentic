{
  "version": 1,
  "top_level_required": [
    "cases"
  ],
  "case_required": [
    "name",
    "path",
    "kind",
    "expect_conformance",
    "expected_route",
    "expected_verification",
    "expected_failure_mode"
  ],
  "case_optional": [
    "expected_error_contains"
  ],
